---
interface Props{
    img: string
    alt: string
}

const {img, alt} = Astro.props
---

<li>
    <img src={img} alt={alt}>
</li>
<style>
    @media(min-width: 1080px){
        li{
            width: 450px;
            height: 600px;
        }
        li:hover{
            width: 500px;
            height: 650px;
            transition: ease 0.2s;

            img{
                filter: grayscale(0);
            }
        }
        img{
            border-radius: 5px;
            width: 100%;
            height: 100%;
            filter: grayscale(1);
        }
    }
</style>