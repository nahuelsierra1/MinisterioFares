---
interface Props{
    titulo: string
    img: string
    alt: string
    href: string
}

const { titulo, img, alt, href} = Astro.props
---

<li class="flex justify-center items-center flex-col">
    <h3 class="font-black text-4xl text-white mb-10 text-center">{titulo}</h3>
    <button class="bg-red-500 py-2 px-5 rounded"><a href={href} class="text-white font-semibold">Ver Galeria</a></button>
    <img src={img} alt={alt}>
    <div class="capa"></div>
</li>

<style>
    @media (min-width: 1080px){
    li{
        width: 20%;
        height: 350px;
        background-color: white;
        position: relative;
        overflow: hidden;
    }
    li:hover{
        .capa{
            background: none;
        }
    }
    img{
        position: absolute;
        top: 0px;
        left: 0px;
        width: 100%;
        height: 100%;
    }
    h3,button{
        z-index: 2;
    }
    .capa{
        position: absolute;
        top: 0px;
        left: 0px;
        width: 100%;
        height: 100%;
        background: rgb(0,0,0);
        background: linear-gradient(0deg, rgba(0,0,0,1) 0%, rgba(255,255,255,0) 100%);
    }
    }
</style>