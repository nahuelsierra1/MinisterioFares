---
interface Props{
    titulo: string
    texto: string
    img: string
    alt: string
}

const { titulo, texto, img, alt} = Astro.props
---

<div class="px-10 py-8 section">
    <div class="contenido">
        <h1 class="font-black text-2xl">{titulo}</h1>
        <p class="font-extralight mt-4">{texto}</p>
        
        <input type="button" value="Conocer mas" class="px-6 py-1 mt-6 rounded-xl">
    </div>
    <img src={img} alt={alt}>
    <div class="capa"></div>
</div>
<style>
    .section{
        position: relative;
        height: 270px;
    }
    .contenido{
        position: relative;
        z-index: 2;
    }
    img{
        position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
    }
    .capa{
        position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: black;
        background: linear-gradient(90deg, rgba(0,0,0,1) 0%, rgba(210,6,6,0) 100%);
    }
    input{
        background-color: rgb(0, 107, 179);
    }

    .section:hover{
        transition: all 0.5s;
        h1{
            font-size: 180%;
            transition: all 0.5s;
        }
        p{
            font-size: 110%;
            transition: all 0.5s;
        }
        .capa{
            background: linear-gradient(90deg, rgba(0,0,0,0.958420868347339) 100%, rgba(210,6,6,0) 100%);
            transition: all 0.5s;
        }
    }
    input:hover{
        background-color: rgb(0, 153, 255);
        transition: all 0.5s;
        cursor: pointer;
    }
    
</style>

