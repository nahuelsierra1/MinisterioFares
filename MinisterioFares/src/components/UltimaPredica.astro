---
import {Image} from 'astro:assets';
import Auriculares from '../img/auriculares.png';
---
<section class="flex justify-center items-center flex-col" id="ultimapredica">
    <div class="texto">
        <h2 class="font-semibold">ULTIMA PREDICA</h2>
        <h1 class="font-bold text-5xl">ZARENDEO</h1>
        <h4 class="font-semibold text-gray-500">ESCUCHALA AHORA</h4>
    </div>

    <div class="apispotify">
        <iframe src="https://open.spotify.com/embed/track/0oqjhpSFAXfgczQD5PEYFX?utm_source=generator&theme=0" 
        width="100%" height="354px" allowfullscreen="" 
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
        loading="lazy"></iframe>
    </div>
    <Image src={Auriculares} alt='Escucha Fares' class='imagen'></Image>
</section>

<style>
    section{
        background-color: rgb(7, 7, 7);
        padding: 100px 0px;
    }
    h2{
        color: #AFD206;
    }


    @media (min-width: 1080px){
        section{
            z-index: 1;
            display: flex;
            flex-direction: row-reverse;
            padding: none;
        }
        .texto{
            padding-left: 100px;
            z-index: 3;
        }
        .apispotify{
            width: 354px;
            border-radius: 0px;
            z-index: 3;
        }
        .imagen{
            position: absolute;
            z-index: 2;
            width: 600px;
        }
    }
</style>