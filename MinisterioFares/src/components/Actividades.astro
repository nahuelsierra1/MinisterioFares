<style>
    .slider{
        display: none;
    }
    section{
    }
    .cartas{
        display: block;
        height: 790px;
        overflow: hidden;
    }
    input{
        background-color: rgb(0, 153, 255);
    }
    input:hover{
        background-color: rgb(90, 189, 255);
        transition: all 0.5s;
        cursor: pointer;
    }
    .estirar{
        height: 1340px;
    }

    @media (min-width: 1080px){
        .cartas{
            display: none;
        }
        .contenido{
            margin: 100px 0px;
        }
        .slider {
            width: 100%;
            height: auto;
            margin: auto;
            overflow: hidden;
            display: block;
        }

        .slider .slide-track {
            display: flex;
            animation: scroll 40s linear infinite;
            -webkit-animation: scroll 40s linear infinite;
            width: calc(200px * 14);
        }

        .slider .slide {
            width: 100%;
        }

        @keyframes scroll {
            0% {
                -webkit-transform: translateX(0);
                transform: translateX(0);
            }
            100% {
                -webkit-transform: translateX(calc(0px * 7));
                transform: translateX(calc(-200px * 7));
            }
        }
    }
</style>