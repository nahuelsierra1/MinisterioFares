---
import {Image} from 'astro:assets';

import Imagen1 from '../img/1.jpg'
import Imagen2 from '../img/1.jpg'
import Imagen3 from '../img/1.jpg'

import Cartas from './Cartas.astro';
---

<script>
    const boton = document.getElementById('boton');
    const cartas = document.getElementById('cartas');

    function Estirar(){
        if(cartas.classList.contains('estirar') == false){
            cartas.classList.add('estirar');
            cartas.style['transition'] = 'all 0.5s';
        }else{
            cartas.style['transition'] = 'all 0.5s';
            cartas.classList.remove('estirar');
        }

    }

    boton.addEventListener('click', Estirar);
</script>
 
