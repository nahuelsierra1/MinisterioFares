---
import VideoBackground from '../videos/VideoBackground.mp4'
---
<section class="" id="inicio">
    <div>
        <h1 class="text-white text-7xl font-bold z">UN <br>LUGAR PARA LA <span class="color font-black">FAMILIA</span></h1>

        <video muted loop autoplay>
            <source src={VideoBackground} type="video/mp4">
        </video>
        <div class="capa">

        </div>
    </div>
</section>

<style>
    .z{
		width: 400px;
		position: relative;
		z-index: 2;
	}

	section{
		height: 100vh;
		position: relative;
		padding: 0px 100px;
	}

	video{
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	h1{
		line-height: 0.8;
	}

	.color{
		color: #AFD206;
	}
	
	@media (min-width: 1080px){
		h1{
			font-size: 150px;
			position: absolute;
			top: 200px;
			left: 0px;
			animation-duration: 1.4s;
			animation-name: slidein;
			animation-delay: 0.5s;
		}

		@keyframes slidein {
		from {
			left: -800px;
		}

		to {
			left: 0px;
		}
		}
	}
</style>
