---
import {Image} from 'astro:assets';
import Logo from '../img/Fares-logo.png';
import X from '../img/x.svg';
---

<header>
	<nav>
		<input type="checkbox" id="check">
		<div class="logo">
      <a href="index.astro"><Image src={Logo} alt='Logo de Fares'></Image></a>
      </div>
		<ul class="flex items-center justify-center">
      <label for="check" class="cerrar checkbtn">
        <Image src={X} alt='cerrar' class='x'></Image>
      </label>
      <div class="lista">
        <li><a href="#ubicacion">Horarios</a></li>
        <li><a href="#">Ultima Predica</a></li>
        <li><a href="#">Actividades</a></li>
        <li><a href="#">¿Quienes somos?</a></li>
        <li><a href="#">Donar</a></li>
        <li><a href="#">Contacto</a></li>
      </div>

		</ul>
		<label for="check" class="checkbtn">
			<i class="fas fa-bars"></i>
		  </label>
	  </nav>
	  <section></section>
</header>

<style>
	*{
  padding: 0;
  margin: 0;
  text-decoration: none;
  list-style: none;
  box-sizing: border-box;
}

header{
  position: relative;
  z-index: 4;
}

nav{
	display: flex;
	justify-content: space-around;
	align-items: center;
  width: 100%;
}

.logo{
  width: 60px;
  margin: 20px 0px;
}

nav ul{
  float: right;
  display: flex;
  justify-content: center;
  flex-direction: column;
}
nav ul li{
	cursor: pointer;
}
nav ul li a{
  font-size: 17px;
  text-transform: uppercase;
}
a.active,a:hover{
  transition: .5s;
}
.checkbtn{
  font-size: 30px;
  cursor: pointer;
  display: none;
}
#check{
  display: none;
}
@media (max-width: 952px){
  label.logo{
    font-size: 30px;
    padding-left: 50px;
  }
  nav ul li a{
    font-size: 16px;
  }
}
@media (max-width: 858px){
  .checkbtn{
    display: block;
  }
  ul{
    position: fixed;
    width: 100%;
	  height: 100vh;
    right: -750px;
    top: 0px;
    transition: all .5s;
	  background-color: rgb(0, 0, 0, 0.9);
  }
  nav ul li{
    text-align: center;
	  padding: 20px;
	  cursor: pointer;
  }
  nav ul li:hover{
	background-color: rgb(5, 5, 5);
    width: 700px;
  }
  nav ul li a{
    font-size: 20px;
  }
  a:hover,a.active{
    background: none;
  }

  #check:checked ~ header{
    background-color: rgb(0, 0, 0, 0.9);
  }

  #check:checked ~ ul{
    display: flex;
    right: 0px;
    height: 100vh;
  }
}

.cerrar{
  position: absolute;
  top: 40px;
}
</style>